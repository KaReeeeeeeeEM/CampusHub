NODE_ENV="development"
APP_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MONGODB_URI="mongodb://127.0.0.1:27017/campushub"
MONGODB_DB_NAME="campushub"
BETTER_AUTH_SECRET="replace-with-a-strong-secret"
BETTER_AUTH_URL="http://localhost:3000"
CAMPUSHUB_ACQUISITION_SECRET="replace-with-a-server-only-acquisition-secret"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
OPENROUTESERVICE_API_KEY=""
SUPER_ADMIN_EMAIL="admin@campushub.com"
SUPER_ADMIN_PASSWORD="ChangeMe@123456"

# Firebase Cloud Messaging
FEATURE_FIREBASE_NOTIFICATIONS="true"
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
# Alternative to FIREBASE_PROJECT_ID/FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY:
# FIREBASE_SERVICE_ACCOUNT_JSON=""

# Runtime Feature Flags
FEATURE_PASSKEY_LOGIN="true"
FEATURE_AUTHENTICATOR_APP="true"
FEATURE_PROFILE_CUSTOMIZATION="true"
FEATURE_STUDENT_DOCUMENT_REPOSITORY="true"
FEATURE_DOCUMENT_VIEWER="true"
FEATURE_NOTIFICATIONS="true"
FEATURE_PWA="true"
FEATURE_PUSH_ARCHITECTURE="true"
FEATURE_ALMANAC_REMINDERS="true"
FEATURE_EVENT_REMINDERS="true"
FEATURE_ANNOUNCEMENT_REMINDERS="true"
FEATURE_XP_REWARD_POPUPS="true"
FEATURE_BIRTHDAY_REMINDERS="true"
FEATURE_XP_GIFTING="true"
FEATURE_CAMPUS_NAVIGATION="true"
FEATURE_MARKETPLACE="true"
FEATURE_COURSE_MANAGEMENT="true"
FEATURE_ALUMNI_AUTO_TRANSITION="true"
ENABLE_OPENROUTESERVICE_DIRECTIONS="true"
DISABLE_DUMMY_DATA="true"
